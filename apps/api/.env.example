# Port for the Express server to listen on
PORT=4000

# URL of the frontend (for CORS configurations)
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection string (Optional: if omitted, server operates in-memory)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# API Key for Google Gemini (Stage 1 Mapping and Stage 2 Extraction)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key for Groq (Llama 3.3 Fallback Engine)
GROQ_API_KEY=your_groq_api_key_here
